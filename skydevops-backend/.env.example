# ==============================
# SkyDevOps Backend - ENV Config
# ==============================

PORT=5000

# MongoDB Atlas Connection
MONGO_URI=mongodb+srv://youruser:yourpassword@cluster0.mongodb.net/skydevops

# JWT Secret (use a long random string)
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long

# Admin Credentials (first-time setup)
ADMIN_EMAIL=admin@skydevopssolution.com
ADMIN_PASSWORD=Admin@123

# Email (Nodemailer - Gmail SMTP)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password

# Frontend URL (for CORS)
FRONTEND_URL=https://yourusername.github.io
